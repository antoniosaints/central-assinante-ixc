# URL base do backend intermediário (nunca a API externa direto).
# Em dev, deixe vazio para usar o proxy do Vite (/api -> localhost:3333).
VITE_API_BASE_URL=/api
VITE_API_TIMEOUT=15000

# Cor primária de todo o app (hex, ENTRE ASPAS por causa do #).
# Os tons claro/escuro são derivados dela. Reinicie o dev server ao mudar.
VITE_PRIMARY_COLOR="#0082b1"
