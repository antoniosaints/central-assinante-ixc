# Porta do backend
PORT=3333

# Origem permitida (frontend)
CORS_ORIGIN=http://localhost:5173

# ----- API do provedor IXCSoft -----
# Enquanto IXC_API_URL/USER/PASSWORD estiverem vazios, o login usa o mock.
# Basic Auth: usuário e senha (token) fornecidos pelo provedor.
IXC_API_URL=
IXC_API_USER=
IXC_API_PASSWORD=
IXC_API_TIMEOUT=20000

# ----- API externa genérica (demais serviços — integração futura) -----
# Enquanto vazio, os serviços (financeiro, consumo, relatórios) usam mocks.
PROVIDER_API_BASE_URL=
PROVIDER_API_TOKEN=
PROVIDER_API_TIMEOUT=15000
