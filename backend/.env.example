# Porta do backend
PORT=3333

# Origem permitida (frontend)
CORS_ORIGIN=http://localhost:5173

# ----- API do provedor IXCSoft -----
# Enquanto IXC_API_URL/USER/PASSWORD estiverem vazios, o login usa o mock.
# Basic Auth: usuário e senha (token) fornecidos pelo provedor.
IXC_API_URL=
IXC_API_USER=
IXC_API_PASSWORD=
# Timeout POR TENTATIVA (ms). Há retry automático, então prefira um valor menor.
IXC_API_TIMEOUT=12000
# Tentativas extras em falhas transitórias (timeout/rede/5xx). 0 desliga.
IXC_API_RETRIES=2
# Base do backoff entre tentativas (ms): 300, 600, ...
IXC_API_RETRY_DELAY=300

# ----- API externa genérica (demais serviços — integração futura) -----
# Enquanto vazio, os serviços (financeiro, consumo, relatórios) usam mocks.
PROVIDER_API_BASE_URL=
PROVIDER_API_TOKEN=
PROVIDER_API_TIMEOUT=15000
